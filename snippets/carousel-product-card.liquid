<div class="carousel-card">
  <div class="carousel-card-image">
    <span class="carousel-badge">Novidade</span>
    <button class="carousel-fav" aria-label="Favoritar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </button>
    <a href="{{ product.url }}">
      <img src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | escape }}"
        loading="lazy" width="600" height="800">
    </a>
  </div>
  <div class="carousel-card-info">
    <h3>{{ product.title | upcase }}</h3>
    {%- if product.metafields.custom.wholesale_price -%}
      <div class="price-comparison-layout" style="margin-top:0.4rem;">
        <div class="price-column varejo-column">
          <span class="price-label">VAREJO</span>
          <span class="price-value" style="font-size:0.9rem;">{{ product.price | money }}</span>
        </div>
        <div class="price-column atacado-column">
          <span class="price-label">ATACADO</span>
          <span class="price-value atacado-price" style="font-size:0.9rem;">{{ product.metafields.custom.wholesale_price.value | money }}</span>
        </div>
      </div>
      <div class="price-details" style="margin-top:0.3rem;">
        <p class="pix-price">ou {{ product.price | times: 0.95 | money }} no PIX</p>
        <p class="installments">6x de {{ product.price | divided_by: 6 | money }} SEM JUROS</p>
      </div>
    {%- else -%}
      <p class="pix-price" style="margin-top:0.4rem;">ou {{ product.price | times: 0.95 | money }} no PIX</p>
      <p class="price-value" style="font-size:0.95rem;font-weight:800;color:#18181b;margin:0.1rem 0;">{{ product.price | money }}</p>
      <p class="installments">6x de {{ product.price | divided_by: 6 | money }} SEM JUROS</p>
    {%- endif -%}
  </div>
</div>
