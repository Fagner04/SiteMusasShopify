<!doctype html>
  <link rel="shortcut icon" href="https://cdn.shopify.com/s/files/1/0792/8335/5885/files/image_645d5837.png?v=1781359891" />

<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <script>
    // Prevent iOS Safari zoom on input focus
    (function(){
      var viewport = document.querySelector('meta[name=viewport]');
      function disableZoom() {
        viewport.setAttribute('content', 'width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no');
      }
      function enableZoom() {
        viewport.setAttribute('content', 'width=device-width, initial-scale=1');
      }
      document.addEventListener('focusin', function(e) {
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') {
          disableZoom();
        }
      });
      document.addEventListener('focusout', function(e) {
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') {
          enableZoom();
        }
      });
    })();
  </script>  <meta name="theme-color" content="{{ settings.color_header_bg }}">
  <title>{{ page_title }} - {{ shop.name }}</title>
  <meta name="description" content="{{ page_description | escape }}">

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <style>
    :root {
      --brand-orange: {{ settings.color_primary }};
      --brand-purple: {{ settings.color_secondary }};
      --background: {{ settings.color_background }};
      --foreground: {{ settings.color_foreground }};
      --header-bg: {{ settings.color_header_bg }};
      --header-text: {{ settings.color_header_text }};
      --header-icons: {{ settings.color_header_icons }};
      --badge-cart-bg: {{ settings.color_badge_cart_bg }};
      --badge-cart-text: {{ settings.color_badge_cart_text }};
      --cart-bg: {{ settings.color_cart_bg }};
      --cart-text: {{ settings.color_cart_text }};
      --cart-btn-bg: {{ settings.color_cart_btn_bg }};
      --cart-btn-text: {{ settings.color_cart_btn_text }};
      --header-opacity: {{ settings.header_opacity | divided_by: 100.0 }};
      --footer-bg: {{ settings.color_footer_bg }};
      --footer-text: {{ settings.color_footer_text }};
      --btn-bg: {{ settings.color_btn_bg }};
      --btn-text: {{ settings.color_btn_text }};
      --tab-active-bg: {{ settings.color_tab_active }};
      --tab-active-text: {{ settings.color_tab_active_text }};
      --pix-color: {{ settings.color_pix }};
      --badge-bg: {{ settings.color_badge_bg }};
    }

    /* Prevent iOS Safari auto-zoom on input focus */
    @media (max-width: 1023px) {
      input, textarea, select {
        font-size: 16px !important;
      }
    }
  </style>
</head>
<body>

<!-- THEME ACTIVATION GATE — ConectWhats Anti-Pirataria -->
<script>
(function(){
  var SUPABASE_URL = 'https://kgjtweydkggbbfncnpxc.supabase.co';
  var API = SUPABASE_URL + '/functions/v1/activate-theme';
  var TOKEN = {{ settings.theme_activation_token | default: '' | strip | json }};
  var CACHE_KEY = '_cw_lic';
  var CACHE_TTL = 86400000; // 24h em ms

  // Sem token configurado — não bloqueia (ambiente de desenvolvimento)
  if (!TOKEN || TOKEN === '') return;

  // Verifica cache válido
  try {
    var cached = JSON.parse(localStorage.getItem(CACHE_KEY) || 'null');
    if (cached && cached.valid && (Date.now() - cached.ts) < CACHE_TTL) return;
  } catch(e) {}

  // Chama API de validação
  fetch(API, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ token: TOKEN, domain: window.location.hostname })
  })
  .then(function(r) { return r.json().then(function(d) { return { status: r.status, data: d }; }); })
  .then(function(res) {
    if (res.data && res.data.valid) {
      // Token válido — salva cache
      try { localStorage.setItem(CACHE_KEY, JSON.stringify({ valid: true, ts: Date.now() })); } catch(e) {}
    } else {
      // Token inválido ou pirataria — bloqueia
      _cwBlock(res.data && res.data.error ? res.data.error : 'Licença inválida.');
    }
  })
  .catch(function() {
    // Erro de rede — não bloqueia para evitar falso positivo
  });

  function _cwBlock(msg) {
    // Bloqueia scroll
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';

    var gate = document.createElement('div');
    gate.id = '_cw_gate';
    gate.style.cssText = 'position:fixed;inset:0;background:rgba(10,10,10,0.97);z-index:2147483647;display:flex;align-items:center;justify-content:center;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;';
    gate.innerHTML = '<div style="background:#fff;border-radius:1.25rem;padding:2.5rem 2rem;max-width:400px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.4);text-align:center;">'
      + '<div style="width:56px;height:56px;background:#fef2f2;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;font-size:1.75rem;">🔒</div>'
      + '<h2 style="font-size:1.15rem;font-weight:700;color:#18181b;margin:0 0 .5rem;">Tema não licenciado</h2>'
      + '<p style="color:#71717a;font-size:.85rem;margin:0 0 1rem;line-height:1.5;">' + _cwEsc(msg) + '</p>'
      + '<p style="color:#a1a1aa;font-size:.75rem;margin:0;background:#f4f4f5;border-radius:.5rem;padding:.6rem .75rem;">Para obter uma licença, entre em contato com o desenvolvedor do tema.</p>'
      + '</div>';
    document.body.appendChild(gate);

    // Remove conteúdo do body para não ficar acessível via DevTools
    var main = document.getElementById('main-content');
    if (main) main.innerHTML = '';
  }

  function _cwEsc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
})();
</script>
<!-- END ACTIVATION GATE -->

  {% section 'header' %}

  <main id="main-content" style="padding-top:0;">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Cart Drawer -->
  {% render 'cart-drawer' %}

  <!-- Cookie Banner -->
  {% render 'cookie-banner' %}

  <!-- WhatsApp Chat -->
  {% render 'whatsapp-button' %}

  <!-- Promo Popup -->
  {% render 'promo-popup' %}
  {% render 'conectwhats-checkout' %}

  <script src="{{ 'theme.js' | asset_url }}?v={{ 'now' | date: '%s' }}" defer></script>
  <script src="{{ 'supabase.js' | asset_url }}" defer></script>
  <script>
    function setHeaderHeight(){
      var ann=document.getElementById('announcement-bar');
      var hdr=document.getElementById('site-header');
      var annH=ann?ann.offsetHeight:0;
      var hdrH=hdr?hdr.offsetHeight:0;
      document.documentElement.style.setProperty('--header-h',(annH+hdrH)+'px');
      document.documentElement.style.setProperty('--header-only-h',hdrH+'px');
    }
    document.addEventListener('DOMContentLoaded',setHeaderHeight);
    window.addEventListener('resize',setHeaderHeight);
  </script>
  <script>
    window.__cwAtacado = {
      enabled: {{ settings.conectwhats_atacado_enabled | json }},
      min_qty: {{ settings.conectwhats_atacado_min_qty | default: 6 }}
    };
    window.__cwAcessorio = {
      enabled: {{ settings.atacado_acessorio_enabled | json }},
      tag: {{ settings.atacado_acessorio_tag | default: 'acessorio' | json }},
      min_value: parseFloat({{ settings.atacado_acessorio_min_value | default: '100.00' | json }}) * 100
    };
    window.__cwStockAPI = {
      url: {{ settings.conectwhats_stock_api_url | default: 'https://kgjtweydkggbbfncnpxc.supabase.co/functions/v1/check-stock-locks' | json }},
      key: {{ settings.conectwhats_api_key | default: '' | json }}
    };
    window._tagsCache = {};
    window.getProductTags = function(handle) {
      if (window._tagsCache[handle] !== undefined) return Promise.resolve(window._tagsCache[handle]);
      return fetch('/products/' + handle + '.js')
        .then(function(r){ return r.json(); })
        .then(function(p){
          window._tagsCache[handle] = (p.tags || []).map(function(t){ return t.toLowerCase().trim(); });
          return window._tagsCache[handle];
        })
        .catch(function(){ window._tagsCache[handle] = []; return []; });
    };
  </script>
</body>
</html>
